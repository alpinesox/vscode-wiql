{
  "name": "vscode-wiql",
  "displayName": "WIQL",
  "description": "Language support for Azure DevOps Work Item Query Language files.",
  "version": "0.0.1",
  "publisher": "alpinesox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpinesox/vscode-wiql.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:wiql"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "wiql",
        "aliases": [
          "WIQL",
          "wiql"
        ],
        "extensions": [
          ".wiql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wiql",
        "scopeName": "source.wiql",
        "path": "./syntaxes/wiql.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[wiql]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 4
      }
    }
  },
  "scripts": {
    "check:main": "node -e \"const fs=require('fs');const pkg=require('./package.json');if(!fs.existsSync(pkg.main)){throw new Error('Missing extension entry point: '+pkg.main)}\"",
    "compile": "tsc -p ./",
    "list:vsix": "vsce ls --tree",
    "package:vsix": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && vsce package --out dist/vscode-wiql.vsix",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
